<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Health Connect permissions -->
    <uses-permission android:name="android.permission.health.READ_HEART_RATE"
        tools:ignore="HealthConnectPolicy" />
    <uses-permission android:name="android.permission.health.WRITE_HEART_RATE"
        tools:ignore="HealthConnectPolicy" />
    <uses-permission android:name="android.permission.health.READ_EXERCISE"
        tools:ignore="HealthConnectPolicy" />
    <uses-permission android:name="android.permission.health.WRITE_EXERCISE"
        tools:ignore="HealthConnectPolicy" />
    <uses-permission android:name="android.permission.health.READ_TOTAL_CALORIES_BURNED"
        tools:ignore="HealthConnectPolicy" />
    <uses-permission android:name="android.permission.health.WRITE_TOTAL_CALORIES_BURNED"
        tools:ignore="HealthConnectPolicy" />
    <uses-permission android:name="android.permission.health.READ_DISTANCE"
        tools:ignore="HealthConnectPolicy" />
    <uses-permission android:name="android.permission.health.WRITE_DISTANCE"
        tools:ignore="HealthConnectPolicy" />
    <uses-permission android:name="android.permission.health.READ_SPEED"
        tools:ignore="HealthConnectPolicy" />
    <uses-permission android:name="android.permission.health.WRITE_SPEED"
        tools:ignore="HealthConnectPolicy" />
    <uses-permission android:name="android.permission.health.READ_STEPS"
        tools:ignore="HealthConnectPolicy" />
    <uses-permission android:name="android.permission.health.WRITE_STEPS"
        tools:ignore="HealthConnectPolicy" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"
        tools:ignore="ForegroundServicesPolicy" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_HEALTH"/>
    <uses-permission android:name="android.permission.HIGH_SAMPLING_RATE_SENSORS"
        tools:ignore="HighSamplingRate" />

    <!-- Keep screen on during workout -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Required to check if Health Connect app is installed -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
    </queries>

    <application
        android:allowBackup="true"
        android:name=".WalkRushApplication"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WalkRush">

        <!-- Android 14+ permission rationale alias -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

        <!-- Pre-Android 14 onboarding support -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.WalkRush">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Deep link for auth callback -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="walkrush"
                    android:host="callback" />
            </intent-filter>
            <!-- Pre-Android 14 Health Connect onboarding intent -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_ONBOARDING" />
            </intent-filter>
        </activity>

        <!-- Android 14+ onboarding alias -->
        <activity-alias
            android:name="UAndAboveOnboardingActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.health.START_ONBOARDING">
            <intent-filter>
                <action android:name="android.health.connect.action.SHOW_ONBOARDING" />
            </intent-filter>
        </activity-alias>

    </application>

</manifest>
